<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="flex items-center space-x-4">
      <a href="/admin/questions" class="text-gray-400 hover:text-gray-500">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <h1 class="text-2xl font-semibold text-gray-900"><%= title %></h1>
    </div>
  </div>

  <div class="px-4 sm:px-6 md:px-0 mt-8 max-w-4xl">
    <% if (error) { %>
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= error %></h3>
          </div>
        </div>
      </div>
    <% } %>

    <form action="/admin/questions" method="POST" enctype="multipart/form-data" class="space-y-8 divide-y divide-gray-200 bg-white p-8 rounded-lg shadow-sm border border-gray-100">
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-6">
          <label for="content" class="block text-sm font-medium text-gray-700">Pertanyaan *</label>
          <div class="mt-1">
            <textarea id="content" name="content" rows="4" required class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border border-gray-300 rounded-md p-2"></textarea>
          </div>
        </div>

        <div class="sm:col-span-6">
          <label for="questionImage" class="block text-sm font-medium text-gray-700">Gambar Soal (Opsional)</label>
          <div class="mt-1">
            <input type="file" id="questionImage" name="questionImage" accept="image/*" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="questionType" class="block text-sm font-medium text-gray-700">Tipe Soal *</label>
          <div class="mt-1">
            <select id="questionType" name="questionType" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
              <option value="MULTIPLE_CHOICE">Pilihan Ganda</option>
              <option value="TRUE_FALSE">Benar/Salah</option>
              <option value="LIKERT">Skala Likert</option>
              <option value="SHORT_ANSWER">Isian Singkat</option>
            </select>
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="dimensionGroup" class="block text-sm font-medium text-gray-700">Dimensi / Kategori</label>
          <div class="mt-1">
            <input type="text" name="dimensionGroup" id="dimensionGroup" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="Contoh: reasoning">
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="timeLimitSeconds" class="block text-sm font-medium text-gray-700">Batas Waktu (Detik)</label>
          <div class="mt-1">
            <input type="number" name="timeLimitSeconds" id="timeLimitSeconds" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="Opsional">
          </div>
        </div>
      </div>

      <div class="pt-8">
        <div>
          <h3 class="text-lg leading-6 font-medium text-gray-900">Pilihan Jawaban</h3>
          <p class="mt-1 text-sm text-gray-500">Kosongkan jika bukan pilihan ganda. Pilihan akan diberi label otomatis (A, B, C, D) jika label dikosongkan.</p>
        </div>
        
        <div class="mt-6 space-y-4">
          <!-- Option 1 -->
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-md flex-wrap">
            <div class="w-16">
              <label class="block text-xs text-gray-500 mb-1">Label</label>
              <input type="text" name="options[0][label]" placeholder="A" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <label class="block text-xs text-gray-500 mb-1">Teks Pilihan</label>
              <input type="text" name="options[0][content]" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <label class="block text-xs text-gray-500 mb-1">Gambar Pilihan (Opsional)</label>
              <input type="file" name="optionImage_0" accept="image/*" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="w-24">
              <label class="block text-xs text-gray-500 mb-1">Skor / Bobot</label>
              <input type="number" name="options[0][scoreValue]" value="0" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
          </div>

          <!-- Option 2 -->
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-md flex-wrap">
            <div class="w-16">
              <input type="text" name="options[1][label]" placeholder="B" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="text" name="options[1][content]" placeholder="Teks Pilihan" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="file" name="optionImage_1" accept="image/*" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="w-24">
              <input type="number" name="options[1][scoreValue]" value="0" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
          </div>

          <!-- Option 3 -->
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-md flex-wrap">
            <div class="w-16">
              <input type="text" name="options[2][label]" placeholder="C" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="text" name="options[2][content]" placeholder="Teks Pilihan" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="file" name="optionImage_2" accept="image/*" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="w-24">
              <input type="number" name="options[2][scoreValue]" value="0" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
          </div>

          <!-- Option 4 -->
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-md flex-wrap">
            <div class="w-16">
              <input type="text" name="options[3][label]" placeholder="D" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="text" name="options[3][content]" placeholder="Teks Pilihan" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="file" name="optionImage_3" accept="image/*" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="w-24">
              <input type="number" name="options[3][scoreValue]" value="0" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
          </div>
          
          <!-- Option 5 -->
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-md flex-wrap">
            <div class="w-16">
              <input type="text" name="options[4][label]" placeholder="E" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="text" name="options[4][content]" placeholder="Teks Pilihan" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <input type="file" name="optionImage_4" accept="image/*" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="w-24">
              <input type="number" name="options[4][scoreValue]" value="0" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
          </div>
        </div>
      </div>

      <div class="pt-5">
        <div class="flex justify-end">
          <a href="/admin/questions" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Batal</a>
          <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Simpan Soal</button>
        </div>
      </div>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>
