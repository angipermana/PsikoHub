<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto flex items-center space-x-4">
        <a href="/admin" class="text-gray-400 hover:text-gray-500">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
        <div>
          <h1 class="text-2xl font-semibold text-gray-900">Bank Soal</h1>
          <p class="mt-2 text-sm text-gray-700">Daftar semua soal dari berbagai dimensi dan tipe.</p>
        </div>
      </div>
      <div class="mt-4 sm:mt-0 sm:ml-16 flex space-x-3">
        <a href="/admin/questions/import" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
          Import CSV
        </a>
        <a href="/admin/questions/create" class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
          Tambah Manual
        </a>
      </div>
    </div>
  </div>

  <div class="px-4 sm:px-6 md:px-0 mt-6">
    <div class="bg-gray-50 p-4 rounded-md shadow-sm border border-gray-200">
      <form action="/admin/questions" method="GET" class="flex flex-col sm:flex-row sm:items-end space-y-4 sm:space-y-0 sm:space-x-4">
        <div class="w-full sm:w-1/4">
          <label for="type" class="block text-sm font-medium text-gray-700">Tipe Soal</label>
          <select id="type" name="type" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md border">
            <option value="">Semua Tipe</option>
            <option value="MULTIPLE_CHOICE" <%= filters.type === 'MULTIPLE_CHOICE' ? 'selected' : '' %>>Pilihan Ganda</option>
            <option value="TRUE_FALSE" <%= filters.type === 'TRUE_FALSE' ? 'selected' : '' %>>Benar/Salah</option>
            <option value="LIKERT" <%= filters.type === 'LIKERT' ? 'selected' : '' %>>Skala Likert</option>
            <option value="SHORT_ANSWER" <%= filters.type === 'SHORT_ANSWER' ? 'selected' : '' %>>Isian Singkat</option>
          </select>
        </div>
        <div class="w-full sm:w-1/4">
          <label for="category" class="block text-sm font-medium text-gray-700">Kategori / Dimensi</label>
          <select id="category" name="category" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md border">
            <option value="">Semua Kategori</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="flex space-x-2">
          <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Filter
          </button>
          <a href="/admin/questions" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Reset
          </a>
        </div>
      </form>
    </div>
  </div>

  <div class="px-4 sm:px-6 md:px-0 mt-6">
    <div class="flex flex-col">
      <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
        <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
          <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
            <table class="min-w-full divide-y divide-gray-300">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6 w-1/2">Soal</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Tipe / Dimensi</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Pilihan</th>
                  <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                    <span class="sr-only">Aksi</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                <% if (questions.length === 0) { %>
                  <tr>
                    <td colspan="4" class="py-4 pl-4 pr-3 text-sm text-center text-gray-500 sm:pl-6">Belum ada soal.</td>
                  </tr>
                <% } %>
                <% questions.forEach(q => { %>
                <tr>
                  <td class="py-4 pl-4 pr-3 text-sm sm:pl-6">
                    <div class="text-gray-900 line-clamp-2"><%= q.content %></div>
                    <div class="text-xs text-gray-500 mt-1">Waktu: <%= q.timeLimitSeconds ? q.timeLimitSeconds + ' detik' : 'Tak terbatas' %></div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <span class="inline-flex rounded-full bg-blue-100 px-2 text-xs font-semibold leading-5 text-blue-800"><%= q.questionType %></span>
                    <div class="mt-1 text-xs text-gray-500"><%= q.dimensionGroup || '-' %></div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= q.options.length %> opsi
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <a href="/admin/questions/<%= q.id %>/edit" class="text-indigo-600 hover:text-indigo-900 mr-4">Edit</a>
                    <form action="/admin/questions/<%= q.id %>/delete" method="POST" class="inline-block" onsubmit="return confirm('Hapus soal ini?');">
                      <button type="submit" class="text-red-600 hover:text-red-900">Hapus</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
