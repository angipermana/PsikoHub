<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="flex items-center space-x-4">
      <a href="/admin/questions" class="text-gray-400 hover:text-gray-500">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <h1 class="text-2xl font-semibold text-gray-900"><%= title %></h1>
    </div>
  </div>

  <div class="px-4 sm:px-6 md:px-0 mt-8 max-w-3xl">
    <% if (error) { %>
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= error %></h3>
          </div>
        </div>
      </div>
    <% } %>
    
    <% if (success) { %>
      <div class="rounded-md bg-green-50 p-4 mb-6">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-green-800"><%= success %></h3>
          </div>
        </div>
      </div>
    <% } %>

    <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
      
      <div class="mb-8">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Format File CSV</h3>
        <p class="mt-2 text-sm text-gray-500">
          File CSV yang diunggah harus memiliki header berikut secara persis pada baris pertama:
        </p>
        <div class="mt-4 bg-gray-50 p-4 rounded-md border border-gray-200 font-mono text-xs overflow-x-auto whitespace-nowrap">
          question_content, question_type, dimension_group, time_limit_seconds, option_a, score_a, option_b, score_b, option_c, score_c, option_d, score_d
        </div>
        <div class="mt-4 text-sm text-gray-600">
          <ul class="list-disc pl-5 space-y-1">
            <li><b>question_type</b>: MULTIPLE_CHOICE, TRUE_FALSE, LIKERT, SHORT_ANSWER</li>
            <li><b>time_limit_seconds</b>: Kosongkan jika waktu tak terbatas.</li>
            <li>Jika opsi kurang dari 4, biarkan kolom opsi sisanya kosong.</li>
          </ul>
        </div>
      </div>

      <form action="/admin/questions/import" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-700">Pilih File CSV *</label>
          <div class="mt-2 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md">
            <div class="space-y-1 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div class="flex text-sm text-gray-600 justify-center">
                <label for="csvFile" class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500">
                  <span>Upload a file</span>
                  <input id="csvFile" name="csvFile" type="file" accept=".csv" required class="sr-only">
                </label>
                <p class="pl-1">or drag and drop</p>
              </div>
              <p class="text-xs text-gray-500">
                CSV up to 5MB
              </p>
            </div>
          </div>
        </div>

        <div class="pt-5 flex justify-end">
          <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Proses Import
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const fileInput = document.getElementById('csvFile');
  fileInput.addEventListener('change', function(e) {
    if(this.files && this.files[0]) {
      const fileName = this.files[0].name;
      const label = this.parentElement.querySelector('span');
      label.textContent = fileName;
    }
  });
</script>

<%- include('../../partials/footer') %>
