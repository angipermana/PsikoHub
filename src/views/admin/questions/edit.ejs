<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="flex items-center space-x-4">
      <a href="/admin/questions" class="text-gray-400 hover:text-gray-500">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <h1 class="text-2xl font-semibold text-gray-900"><%= title %></h1>
    </div>
  </div>

  <div class="px-4 sm:px-6 md:px-0 mt-8 max-w-4xl">
    <% if (error) { %>
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= error %></h3>
          </div>
        </div>
      </div>
    <% } %>

    <form action="/admin/questions/<%= question.id %>" method="POST" enctype="multipart/form-data" class="space-y-8 divide-y divide-gray-200 bg-white p-8 rounded-lg shadow-sm border border-gray-100">
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-6">
          <label for="content" class="block text-sm font-medium text-gray-700">Pertanyaan *</label>
          <div class="mt-1">
            <textarea id="content" name="content" rows="4" required class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border border-gray-300 rounded-md p-2"><%= question.content %></textarea>
          </div>
        </div>

        <div class="sm:col-span-6">
          <label for="questionImage" class="block text-sm font-medium text-gray-700">Gambar Soal (Opsional)</label>
          <% if (question.imageUrl) { %>
            <div class="mt-2 mb-2">
              <img src="<%= question.imageUrl %>" alt="Question Image" class="h-32 object-contain border rounded p-1">
              <input type="hidden" name="existingQuestionImage" value="<%= question.imageUrl %>">
            </div>
            <p class="text-xs text-gray-500 mb-1">Upload gambar baru untuk mengganti gambar di atas.</p>
          <% } %>
          <div class="mt-1">
            <input type="file" id="questionImage" name="questionImage" accept="image/*" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="questionType" class="block text-sm font-medium text-gray-700">Tipe Soal *</label>
          <div class="mt-1">
            <select id="questionType" name="questionType" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
              <option value="MULTIPLE_CHOICE" <%= question.questionType === 'MULTIPLE_CHOICE' ? 'selected' : '' %>>Pilihan Ganda</option>
              <option value="TRUE_FALSE" <%= question.questionType === 'TRUE_FALSE' ? 'selected' : '' %>>Benar/Salah</option>
              <option value="LIKERT" <%= question.questionType === 'LIKERT' ? 'selected' : '' %>>Skala Likert</option>
              <option value="SHORT_ANSWER" <%= question.questionType === 'SHORT_ANSWER' ? 'selected' : '' %>>Isian Singkat</option>
            </select>
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="dimensionGroup" class="block text-sm font-medium text-gray-700">Dimensi / Kategori</label>
          <div class="mt-1">
            <input type="text" name="dimensionGroup" id="dimensionGroup" value="<%= question.dimensionGroup %>" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="timeLimitSeconds" class="block text-sm font-medium text-gray-700">Batas Waktu (Detik)</label>
          <div class="mt-1">
            <input type="number" name="timeLimitSeconds" id="timeLimitSeconds" value="<%= question.timeLimitSeconds %>" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
          </div>
        </div>
      </div>

      <div class="pt-8">
        <div>
          <h3 class="text-lg leading-6 font-medium text-gray-900">Pilihan Jawaban</h3>
        </div>
        
        <div class="mt-6 space-y-4">
          <% for(let i=0; i<5; i++) { 
               let opt = question.options[i] || { label: '', content: '', scoreValue: 0, imageUrl: null };
          %>
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-md flex-wrap">
            <div class="w-16">
              <% if(i===0) { %><label class="block text-xs text-gray-500 mb-1">Label</label><% } %>
              <input type="text" name="options[<%= i %>][label]" value="<%= opt.label %>" placeholder="<%= String.fromCharCode(65+i) %>" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <% if(i===0) { %><label class="block text-xs text-gray-500 mb-1">Teks Pilihan</label><% } %>
              <input type="text" name="options[<%= i %>][content]" value="<%= opt.content %>" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="flex-1 min-w-[200px]">
              <% if(i===0) { %><label class="block text-xs text-gray-500 mb-1">Gambar Pilihan</label><% } %>
              <% if(opt.imageUrl) { %>
                <div class="flex items-center gap-2 mb-1">
                  <img src="<%= opt.imageUrl %>" class="h-10 w-10 object-cover border rounded">
                  <input type="hidden" name="options[<%= i %>][existingImageUrl]" value="<%= opt.imageUrl %>">
                </div>
              <% } %>
              <input type="file" name="optionImage_<%= i %>" accept="image/*" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
            <div class="w-24">
              <% if(i===0) { %><label class="block text-xs text-gray-500 mb-1">Skor</label><% } %>
              <input type="number" name="options[<%= i %>][scoreValue]" value="<%= opt.scoreValue %>" class="block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <div class="pt-5">
        <div class="flex justify-end">
          <a href="/admin/questions" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Batal</a>
          <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Update Soal</button>
        </div>
      </div>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>
