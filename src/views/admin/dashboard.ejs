<%- include('../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <h1 class="text-2xl font-semibold text-gray-900">Dashboard Super Admin</h1>
  </div>
  <div class="px-4 sm:px-6 md:px-0 mt-6">
    
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      
      <!-- Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-100">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Klien</dt>
                <dd>
                  <div class="text-lg font-medium text-gray-900"><%= stats.totalClients %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <a href="/admin/clients" class="font-medium text-indigo-600 hover:text-indigo-900">Lihat detail</a>
          </div>
        </div>
      </div>

      <!-- Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-100">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Bank Soal</dt>
                <dd>
                  <div class="text-lg font-medium text-gray-900"><%= stats.totalQuestions %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <a href="/admin/questions" class="font-medium text-indigo-600 hover:text-indigo-900">Lihat detail</a>
          </div>
        </div>
      </div>

      <!-- Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-100">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Paket Tes</dt>
                <dd>
                  <div class="text-lg font-medium text-gray-900"><%= stats.totalPackages %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <a href="/admin/packages" class="font-medium text-indigo-600 hover:text-indigo-900">Lihat detail</a>
          </div>
        </div>
      </div>

      <!-- Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-100">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Project</dt>
                <dd>
                  <div class="text-lg font-medium text-gray-900"><%= stats.totalProjects %></div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <a href="/admin/projects" class="font-medium text-indigo-600 hover:text-indigo-900">Lihat detail</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Quick Links -->
    <div class="mt-8">
      <h2 class="text-lg font-medium text-gray-900">Aksi Cepat</h2>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/admin/clients" class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 transition-colors">
          <div class="flex-1 min-w-0">
            <span class="absolute inset-0" aria-hidden="true"></span>
            <p class="text-sm font-medium text-gray-900">Kelola Akun Klien</p>
            <p class="text-sm text-gray-500 truncate">Tambah atau edit lembaga</p>
          </div>
        </a>
        <a href="/admin/questions" class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 transition-colors">
          <div class="flex-1 min-w-0">
            <span class="absolute inset-0" aria-hidden="true"></span>
            <p class="text-sm font-medium text-gray-900">Kelola Bank Soal</p>
            <p class="text-sm text-gray-500 truncate">Tambah atau import soal (CSV)</p>
          </div>
        </a>
        <a href="/admin/packages" class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 transition-colors">
          <div class="flex-1 min-w-0">
            <span class="absolute inset-0" aria-hidden="true"></span>
            <p class="text-sm font-medium text-gray-900">Kelola Paket Tes</p>
            <p class="text-sm text-gray-500 truncate">Buat bundel soal</p>
          </div>
        </a>
        <a href="/admin/projects" class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 transition-colors">
          <div class="flex-1 min-w-0">
            <span class="absolute inset-0" aria-hidden="true"></span>
            <p class="text-sm font-medium text-gray-900">Kelola Project</p>
            <p class="text-sm text-gray-500 truncate">Distribusi link tes ke peserta</p>
          </div>
        </a>
        <a href="/admin/reports" class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 transition-colors">
          <div class="flex-1 min-w-0">
            <span class="absolute inset-0" aria-hidden="true"></span>
            <p class="text-sm font-medium text-gray-900">Laporan & Hasil</p>
            <p class="text-sm text-gray-500 truncate">Nilai dan export Excel</p>
          </div>
        </a>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
