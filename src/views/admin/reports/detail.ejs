<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <a href="/admin/reports" class="text-gray-400 hover:text-gray-500">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
        <h1 class="text-2xl font-semibold text-gray-900"><%= title %></h1>
      </div>
      <div>
        <a href="/admin/reports/<%= project.id %>/export" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700">
          <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Export Excel
        </a>
      </div>
    </div>
    <div class="mt-2 text-sm text-gray-500">
      Klien: <%= project.clientProfile.institutionName %> | Paket Tes: <%= project.package.name %>
    </div>
  </div>
  
  <div class="px-4 sm:px-6 md:px-0 mt-6">
    <div class="flex flex-col">
      <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
        <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
          <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
            <table class="min-w-full divide-y divide-gray-200 bg-white">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Peserta
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Waktu Selesai
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Skor Total
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Jawaban Benar
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Log Proctoring
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <% if(results.length === 0) { %>
                  <tr>
                    <td colspan="5" class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">Belum ada hasil ujian yang disubmit.</td>
                  </tr>
                <% } %>
                <% results.forEach(r => { %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm font-medium text-gray-900"><%= r.user.name %></div>
                      <div class="text-sm text-gray-500"><%= r.user.email %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900"><%= r.session.finishedAt ? r.session.finishedAt.toLocaleString('id-ID') : '-' %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800">
                        <%= r.totalScore %> PTS
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= r.correctAnswers %> / <%= r.totalQuestions %> Soal
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% if (r.proctoringIssues > 0) { %>
                        <span class="text-red-600 text-sm font-medium"><%= r.proctoringIssues %> Pelanggaran</span>
                      <% } else { %>
                        <span class="text-green-600 text-sm font-medium">Aman</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
