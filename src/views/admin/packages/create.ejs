<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="flex items-center space-x-4">
      <a href="/admin/packages" class="text-gray-400 hover:text-gray-500">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <h1 class="text-2xl font-semibold text-gray-900"><%= title %></h1>
    </div>
  </div>

  <div class="px-4 sm:px-6 md:px-0 mt-8 max-w-4xl">
    <% if (error) { %>
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= error %></h3>
          </div>
        </div>
      </div>
    <% } %>

    <form action="/admin/packages" method="POST" class="space-y-8 divide-y divide-gray-200 bg-white p-8 rounded-lg shadow-sm border border-gray-100">
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-4">
          <label for="name" class="block text-sm font-medium text-gray-700">Nama Paket Tes *</label>
          <div class="mt-1">
            <input type="text" name="name" id="name" required class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="totalTimeMinutes" class="block text-sm font-medium text-gray-700">Total Waktu Pengerjaan (Menit)</label>
          <div class="mt-1">
            <input type="number" name="totalTimeMinutes" id="totalTimeMinutes" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
          </div>
        </div>

        <div class="sm:col-span-6">
          <label for="instructions" class="block text-sm font-medium text-gray-700">Instruksi Tes</label>
          <div class="mt-1">
            <textarea id="instructions" name="instructions" rows="4" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border border-gray-300 rounded-md p-2"></textarea>
          </div>
        </div>

        <div class="sm:col-span-6">
          <div class="relative flex items-start">
            <div class="flex h-5 items-center">
              <input id="randomizeQuestions" name="randomizeQuestions" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            </div>
            <div class="ml-3 text-sm">
              <label for="randomizeQuestions" class="font-medium text-gray-700">Acak Urutan Soal</label>
              <p class="text-gray-500">Soal akan ditampilkan secara acak untuk setiap peserta.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="pt-8">
        <div>
          <h3 class="text-lg leading-6 font-medium text-gray-900">Pilih Soal</h3>
          <p class="mt-1 text-sm text-gray-500">Pilih soal yang akan dimasukkan ke dalam paket tes ini.</p>
        </div>
        
        <div class="mt-6">
          <div class="max-h-96 overflow-y-auto border border-gray-200 rounded-md p-4">
            <% if (questions.length === 0) { %>
              <p class="text-sm text-gray-500 text-center py-4">Belum ada soal di bank soal. Silakan tambahkan soal terlebih dahulu.</p>
            <% } else { %>
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50 sticky top-0">
                  <tr>
                    <th scope="col" class="relative px-6 py-3 w-12">
                      <input type="checkbox" id="selectAll" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kategori/Dimensi</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pertanyaan</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipe</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  <% questions.forEach(q => { %>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <input type="checkbox" name="questionIds" value="<%= q.id %>" class="question-cb h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= q.dimensionGroup || '-' %></td>
                      <td class="px-6 py-4 text-sm text-gray-900 line-clamp-2"><%= q.content %></td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= q.questionType %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
      </div>

      <div class="pt-5">
        <div class="flex justify-end">
          <a href="/admin/packages" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Batal</a>
          <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Simpan Paket</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('selectAll').addEventListener('change', function() {
    const checkboxes = document.querySelectorAll('.question-cb');
    checkboxes.forEach(cb => {
      cb.checked = this.checked;
    });
  });
</script>

<%- include('../../partials/footer') %>
