<%- include('../../partials/header') %>

<div class="py-6">
  <div class="px-4 sm:px-6 md:px-0">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto flex items-center space-x-4">
        <a href="/admin" class="text-gray-400 hover:text-gray-500">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
        <div>
          <h1 class="text-2xl font-semibold text-gray-900">Manajemen Paket Tes</h1>
          <p class="mt-2 text-sm text-gray-700">Daftar paket tes yang merangkum soal-soal dari bank soal untuk diberikan ke peserta.</p>
        </div>
      </div>
      <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <a href="/admin/packages/create" class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto">
          Tambah Paket Baru
        </a>
      </div>
    </div>
    
    <% if (error) { %>
      <div class="rounded-md bg-red-50 p-4 mt-6">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= error %></h3>
          </div>
        </div>
      </div>
    <% } %>

    <div class="mt-8 flex flex-col">
      <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
        <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
          <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
            <table class="min-w-full divide-y divide-gray-300">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Nama Paket</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Total Waktu</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Jumlah Soal</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Acak Soal?</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                  <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                    <span class="sr-only">Aksi</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                <% packages.forEach(pkg => { %>
                <tr>
                  <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6"><%= pkg.name %></td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= pkg.totalTimeMinutes ? pkg.totalTimeMinutes + ' menit' : 'Tidak Terbatas' %></td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= pkg.questions ? pkg.questions.length : 0 %> Soal</td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <% if(pkg.randomizeQuestions) { %>
                      <span class="inline-flex rounded-full bg-blue-100 px-2 text-xs font-semibold leading-5 text-blue-800">Ya</span>
                    <% } else { %>
                      <span class="inline-flex rounded-full bg-gray-100 px-2 text-xs font-semibold leading-5 text-gray-800">Tidak</span>
                    <% } %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <% if(pkg.isActive) { %>
                      <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">Aktif</span>
                    <% } else { %>
                      <span class="inline-flex rounded-full bg-red-100 px-2 text-xs font-semibold leading-5 text-red-800">Nonaktif</span>
                    <% } %>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <a href="/admin/packages/<%= pkg.id %>/edit" class="text-indigo-600 hover:text-indigo-900 mr-4">Edit</a>
                    <form action="/admin/packages/<%= pkg.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Yakin ingin menghapus paket ini? Project yang memakai paket ini mungkin akan bermasalah.');">
                      <button type="submit" class="text-red-600 hover:text-red-900">Hapus</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
                <% if(packages.length === 0) { %>
                  <tr>
                    <td colspan="6" class="whitespace-nowrap py-4 pl-4 pr-3 text-sm text-gray-500 text-center sm:pl-6">Belum ada paket tes yang terdaftar.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
