<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 min-h-screen">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
      Selamat Datang Peserta
    </h2>
    <p class="mt-2 text-center text-sm text-gray-600">
      Project: <span class="font-medium text-indigo-600"><%= project.name %></span><br/>
      Klien: <%= project.clientProfile.institutionName %>
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 border border-gray-100">
      <% if (error) { %>
        <div class="rounded-md bg-red-50 p-4 mb-4">
          <div class="flex">
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Gagal mendaftar. Silakan coba lagi.</h3>
            </div>
          </div>
        </div>
      <% } %>

      <form class="space-y-6" action="/test/<%= project.accessToken %>/register" method="POST">
        <div>
          <label for="fullName" class="block text-sm font-medium text-gray-700">
            Nama Lengkap
          </label>
          <div class="mt-1">
            <input id="fullName" name="fullName" type="text" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">
            Alamat Email
          </label>
          <div class="mt-1">
            <input id="email" name="email" type="email" autocomplete="email" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
          </div>
          <p class="mt-1 text-xs text-gray-500">Gunakan email yang valid untuk menerima hasil (jika disyaratkan).</p>
        </div>

        <div>
          <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Daftar & Lanjut ke Persiapan
          </button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
